KIWOOM_APP_KEY=your_app_key
KIWOOM_APP_SECRET=your_secret_key
KIWOOM_USE_MOCK=false

# Optional. Kiwoom kt00018 usually uses the authenticated account context.
# If Kiwoom requires an account field for your environment, set both values.
KIWOOM_ISA_ACCOUNT_NO=
KIWOOM_ACCOUNT_FIELD=

# Optional defaults
KIWOOM_DMST_STEX_TP=KRX
KIWOOM_BALANCE_QRY_TP=1
KIWOOM_TIMEOUT=15

UPBIT_ACCESS_KEY=your_upbit_access_key
UPBIT_SECRET_KEY=your_upbit_secret_key
UPBIT_API_HOST=https://api.upbit.com
UPBIT_TIMEOUT=10

# Local runs should use backend/assets.db. Keep this true unless you are
# intentionally running the backend against a remote Postgres database.
LOCAL_DB_ONLY=true
DATABASE_URL=

# Used only by scripts/migrate_sqlite_to_supabase.py.
# The backend also uses this when LOCAL_DB_ONLY=false and DATABASE_URL is empty.
SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
